* text=auto eol=lf

# Windows-native scripts should keep CRLF for local execution/editing.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Keep Linux shell entrypoints on LF so CI and containers execute them correctly.
*.sh text eol=lf
gradlew text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.jar binary
*.jks binary
*.keystore binary
*.apk binary
*.aab binary
