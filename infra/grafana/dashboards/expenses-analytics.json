    {
      "id": 11,
      "type": "stat",
      "title": "Median Event Lifetime",
      "description": "Median hours from event creation to last expense added",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 22 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawQuery": true,
          "rawSql": "SELECT ROUND(\n  PERCENTILE_CONT(0.5) WITHIN GROUP (\n    ORDER BY EXTRACT(EPOCH FROM (last_ex - ev.created_at)) / 3600\n  )::numeric, 1\n) AS \"Median Lifetime (h)\"\nFROM \"${postgres_schema}\".event ev\nJOIN (\n  SELECT event_id, MAX(created_at) AS last_ex\n  FROM \"${postgres_schema}\".expense\n  GROUP BY event_id\n) lx ON lx.event_id = ev.id\nWHERE ev.deleted_at IS NULL",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "h"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      }
    },
    {
      "id": 12,
      "type": "piechart",
      "title": "Currency Distribution",
      "description": "How many events use each base currency",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 26 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawQuery": true,
          "rawSql": "SELECT\n  c.code AS \"Currency\",\n  COUNT(DISTINCT e.id) AS \"Events\"\nFROM \"${postgres_schema}\".currency c\nJOIN \"${postgres_schema}\".event e ON e.currency_id = c.id AND e.deleted_at IS NULL\nGROUP BY c.code\nORDER BY \"Events\" DESC",
          "refId": "A",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Activation Rate",
      "description": "% of events created that got at least 1 expense (by day)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 26 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('day', ev.created_at) AS time,\n  ROUND(\n    COUNT(DISTINCT ex.event_id)::numeric / NULLIF(COUNT(DISTINCT ev.id), 0) * 100,\n    1\n  ) AS \"Activation %\"\nFROM \"${postgres_schema}\".event ev\nLEFT JOIN \"${postgres_schema}\".expense ex\n  ON ex.event_id = ev.id AND ex.expense_type = 'expense'\nWHERE $__timeFilter(ev.created_at) AND ev.deleted_at IS NULL\nGROUP BY 1\nORDER BY 1",
          "refId": "A",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "decimals": 1,
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 14,
