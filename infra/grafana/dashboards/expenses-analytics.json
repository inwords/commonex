          "rawQuery": true,
          "rawSql": "SELECT\n  ev.name                          AS \"Event Name\",\n  COUNT(ex.id)                     AS \"Expenses\",\n  COUNT(DISTINCT ui.id)            AS \"Users\",\n  MIN(ex.created_at)::date         AS \"First Expense\",\n  MAX(ex.created_at)::date         AS \"Last Expense\",\n  (MAX(ex.created_at)::date - MIN(ex.created_at)::date) AS \"Active Days\",\n  COUNT(*) FILTER (WHERE ex.is_custom_rate = true) AS \"Custom Rates\"\nFROM \"${postgres_schema}\".event ev\nLEFT JOIN \"${postgres_schema}\".expense ex\n  ON ex.event_id = ev.id AND ex.expense_type = 'expense'\nLEFT JOIN \"${postgres_schema}\".user_info ui\n  ON ui.event_id = ev.id\nWHERE ev.deleted_at IS NULL\nGROUP BY ev.id, ev.name\nORDER BY \"Expenses\" DESC NULLS LAST\nLIMIT 20",
