        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Events\" FROM \"${postgres_schema}\".event WHERE deleted_at IS NULL",
