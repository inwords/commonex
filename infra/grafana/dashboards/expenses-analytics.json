    {
      "id": 5,
      "type": "timeseries",
      "title": "Events Over Time",
      "description": "New events created per day",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('day', created_at) AS time,\n  COUNT(*) AS \"New Events\"\nFROM \"${postgres_schema}\".event\nWHERE $__timeFilter(created_at) AND deleted_at IS NULL\nGROUP BY 1\nORDER BY 1",
          "refId": "A",
          "format": "time_series"
        },
        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('day', created_at) AS time,\n  SUM(COUNT(*)) OVER (ORDER BY date_trunc('day', created_at)) AS \"Cumulative\"\nFROM \"${postgres_schema}\".event\nWHERE deleted_at IS NULL\nGROUP BY 1\nORDER BY 1",
          "refId": "B",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 60,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Cumulative" },
            "properties": [
              { "id": "custom.drawStyle", "value": "line" },
              { "id": "custom.fillOpacity", "value": 10 },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "custom.lineInterpolation", "value": "smooth" }
            ]
          }
        ]
      },
      "options": {
        "legend": { "calcs": ["sum", "last"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      }
    },
