    {
      "id": 9,
      "type": "stat",
      "title": "Avg Users / Event",
      "description": "Average number of participants per event",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 22 },
      "datasource": { "type": "postgres", "uid": "postgres-ds" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgres-ds" },
          "rawQuery": true,
          "rawSql": "SELECT ROUND(AVG(cnt), 1) AS \"Avg Users/Event\"\nFROM (\n  SELECT event_id, COUNT(*) AS cnt\n  FROM \"${postgres_schema}\".user_info\n  GROUP BY event_id\n) t",
          "refId": "A",
          "format": "table"
        }
